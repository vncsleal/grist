#!/usr/bin/env bash
set -euo pipefail

BINARY_PATH="/usr/local/bin/quillby-mcp"

# pkg postinstall runs as root — find the actual logged-in user
CURRENT_USER=$(stat -f "%Su" /dev/console 2>/dev/null || true)
[[ -z "$CURRENT_USER" || "$CURRENT_USER" == "root" ]] && CURRENT_USER="${SUDO_USER:-}"
[[ -z "$CURRENT_USER" || "$CURRENT_USER" == "root" ]] && exit 0

USER_HOME=$(dscl . -read "/Users/$CURRENT_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}' || true)
[[ -z "$USER_HOME" ]] && USER_HOME="/Users/$CURRENT_USER"

CONFIG_DIR="$USER_HOME/Library/Application Support/Claude"
CONFIG_FILE="$CONFIG_DIR/claude_desktop_config.json"

# Ensure directory exists
mkdir -p "$CONFIG_DIR"

# Create config file if missing
[ ! -f "$CONFIG_FILE" ] && echo '{}' > "$CONFIG_FILE"

# Ensure the file is valid JSON (reset if corrupted)
plutil -lint "$CONFIG_FILE" > /dev/null 2>&1 || echo '{}' > "$CONFIG_FILE"

# Ensure mcpServers key exists
plutil -extract mcpServers raw "$CONFIG_FILE" > /dev/null 2>&1 || \
    plutil -insert mcpServers -json '{}' "$CONFIG_FILE"

# Insert quillby entry, or replace if it already exists
plutil -insert "mcpServers.quillby" -json "{\"command\":\"$BINARY_PATH\"}" "$CONFIG_FILE" 2>/dev/null || \
    plutil -replace "mcpServers.quillby" -json "{\"command\":\"$BINARY_PATH\"}" "$CONFIG_FILE"

# Fix ownership so the user owns their own config
chown -R "$CURRENT_USER" "$CONFIG_DIR"

exit 0
