# ─── LLM Provider ────────────────────────────────────────────────────────────
# Set ONE of the following API keys. GRIST auto-detects which provider to use.
# Explicit override: LLM_PROVIDER=openai|anthropic|groq|gemini|openrouter|mistral|xai|together|azure

# OpenAI (default)
OPENAI_API_KEY=sk-...
# Optional: For cost reconciliation with actual OpenAI billing (requires org-level access)
# OPENAI_ORG_ID=org-...      # Organization ID
# Note: Use organization-level API key above, not user-level key

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Groq (free tier available — fast inference)
# GROQ_API_KEY=gsk_...

# Google Gemini (free tier available)
# GOOGLE_API_KEY=AIza...

# OpenRouter (100+ models with one key)
# OPENROUTER_API_KEY=sk-or-...

# Mistral AI
# MISTRAL_API_KEY=...

# xAI (Grok)
# XAI_API_KEY=xai-...

# Together AI (cheap open-model hosting)
# TOGETHER_API_KEY=...

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2025-01-01-preview  # optional, defaults to 2025-01-01-preview

# ─── Model overrides (optional) ───────────────────────────────────────────────
# Each provider has sensible defaults. Override only if needed.
# For OpenRouter, set these to your preferred model slugs (e.g. anthropic/claude-sonnet-4-5)

# LLM_MODEL_FAST=      # filtering & scoring — fast, economical
# LLM_MODEL=           # general purpose
# LLM_MODEL_RESEARCH=  # research & analysis — highest quality
# LLM_MODEL_REASONING= # deep multi-step reasoning
# LLM_MODEL_PRO=       # complex analysis (optional)

# ─── Parallelization ──────────────────────────────────────────────────────────
PARALLEL_WORKERS=4
BATCH_SIZE=10
PARALLEL_REQUESTS=5
